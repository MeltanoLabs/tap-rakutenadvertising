# RakutenAdvertising Configuration
# Copy this file to .env and fill in your actual values

# Required: Authentication token for the API service
TAP_RAKUTENADVERTISING_AUTH_TOKEN=your_auth_token_here

# Optional: The earliest record date to sync (ISO format)
TAP_RAKUTENADVERTISING_START_DATE=2023-01-01T00:00:00Z

# Optional: API URL (defaults to https://api.linksynergy.com)
TAP_RAKUTENADVERTISING_API_URL=https://api.linksynergy.com

# Optional: Filter for the offers stream (active, available, upcoming)
TAP_RAKUTENADVERTISING_OFFER_STATUS=active

# Optional: Search keyword for the product_search stream
# TAP_RAKUTENADVERTISING_PRODUCT_SEARCH_KEYWORD=

# Optional: Advertiser ID filter for the product_search stream
# TAP_RAKUTENADVERTISING_PRODUCT_SEARCH_MID=

# Optional: Advertiser ID for Link Locator streams (-1 = all)
TAP_RAKUTENADVERTISING_LINK_LOCATOR_ADVERTISER_ID=-1

# Optional: Category ID for Link Locator streams (-1 = all)
TAP_RAKUTENADVERTISING_LINK_LOCATOR_CATEGORY_ID=-1

# Optional: Banner size code for the banner_links stream (-1 = all)
TAP_RAKUTENADVERTISING_BANNER_SIZE_CODE=-1
