# RakutenAdvertising Configuration
# Copy this file to .env and fill in your actual values

# Required: Authentication token for the API service
TAP_RAKUTENADVERTISING_AUTH_TOKEN=your_auth_token_here

# Optional: The earliest record date to sync (ISO format)
TAP_RAKUTENADVERTISING_START_DATE=2023-01-01T00:00:00Z

# Optional: API URL (defaults to https://api.linksynergy.com)
TAP_RAKUTENADVERTISING_API_URL=https://api.linksynergy.com

# Optional: Filter for the offers stream (active, available, upcoming)
TAP_RAKUTENADVERTISING_OFFER_STATUS=active

# Optional: Search keyword for the product_search stream
# TAP_RAKUTENADVERTISING_PRODUCT_SEARCH_KEYWORD=

# Optional: Advertiser ID filter for the product_search stream
# TAP_RAKUTENADVERTISING_PRODUCT_SEARCH_MID=

# Optional: Advertiser ID for Link Locator streams (-1 = all)
TAP_RAKUTENADVERTISING_LINK_LOCATOR_ADVERTISER_ID=-1

# Optional: Category ID for Link Locator streams (-1 = all)
TAP_RAKUTENADVERTISING_LINK_LOCATOR_CATEGORY_ID=-1

# Optional: Banner size code for the banner_links stream (-1 = all)
TAP_RAKUTENADVERTISING_BANNER_SIZE_CODE=-1

# Optional: Security token for Advanced Reports API (not the Bearer token)
# TAP_RAKUTENADVERTISING_SECURITY_TOKEN=

# Optional: Payment ID for Advanced Reports advertiser payments (reportid 2/22)
# TAP_RAKUTENADVERTISING_ADVANCED_REPORTS_PAY_ID=

# Optional: Invoice ID for Advanced Reports payment details (reportid 3/23)
# TAP_RAKUTENADVERTISING_ADVANCED_REPORTS_INVOICE_ID=

# Optional: Network ID filter for Advanced Reports (1, 3, 5, 41)
# TAP_RAKUTENADVERTISING_ADVANCED_REPORTS_NETWORK_ID=

# Optional: Reporting Platform (ran-reporting.rakutenmarketing.com)
# API token found in the report URL under 'token=' parameter
# TAP_RAKUTENADVERTISING_REPORTING_API_TOKEN=

# Comma-separated report keys (each becomes a separate stream)
# TAP_RAKUTENADVERTISING_REPORTING_REPORT_KEYS=data_team_monthly_report_us

# Region code (default: en)
# TAP_RAKUTENADVERTISING_REPORTING_REGION=en

# Date type: transaction or process (default: transaction)
# TAP_RAKUTENADVERTISING_REPORTING_DATE_TYPE=transaction
